---
import { Hand } from "@lucide/astro";
---

<section class="flex-center flex-col md:flex-row gap-16 px-8 py-12 md:px-24 md:py-20 bg-[url(../assets/hero-background.png)] bg-left md:bg-right bg-cover">
  <div class="flex-1">
    <p class="flex-center text-slate-600 gap-2 text-xs py-0.5 px-2 border border-slate-300 w-fit rounded-full">
      <Hand size="14" />
      Olá, eu sou
    </p>

    <div class="mt-5 mb-6">
      <h1 class="mb-1 font-poppins text-5xl font-bold">
        Gabriel
        <span class="bg-linear-to-b from-blue-500 to-blue-600 bg-clip-text text-transparent ml-3">
          Couto
        </span>
      </h1>

      <div class="flex-center gap-2">
        <h2 id="typed" class="bg-linear-to-b w-fit from-blue-500 to-blue-600 bg-clip-text text-2xl font-poppins font-semibold text-transparent">
          <!-- Typing animation -->
        </h2>
      </div>
    </div>

    <p class="max-w-100 text-sm leading-6 tracking-wide text-slate-700">
      Lorem ipsum dolor sit amet consectetur adipisicing elit. Eaque esse
      accusantium eum praesentium exercitationem omnis deserunt porro,
      dolorum, laudantium saepe fugit, facere quis quibusdam eos.
    </p>

    <div class="mt-10 mb-8 flex-center gap-6">
      <img src="/technologies/html5.svg" alt="HTML5" class="size-9" />
      <img src="" alt="" class="size-9" />
      <img src="" alt="" class="size-9" />
      <img src="" alt="" class="size-9" />
      <img src="" alt="" class="size-9" />
    </div>

    <div class="flex-center flex-col md:flex-row max-w-100 gap-6">
      <button class="primary-button w-full">Baixar currículo</button>
      <button class="secondary-button w-full">Entrar em contato</button>
    </div>
  </div>

  <div class="flex-1">
    <img src="" alt="" />
  </div>
</section>
<script src="../animations/typing.js" />
