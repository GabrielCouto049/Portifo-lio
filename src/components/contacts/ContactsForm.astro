---
import { Send } from "@lucide/astro";
---

<form class="rounded-2xl
    bg-slate-900/40
    p-8
    backdrop-blur">
  <div class="grid gap-6 md:grid-cols-2">
    <label class="flex flex-col gap-2 text-sm">
      <span class="font-poppins tracking-wide"> Nome </span>

      <input
        id="name"
        name="name"
        type="text"
        required
        autocomplete="name"
        class="rounded-lg
          border border-slate-600
          bg-slate-800
          px-4 py-3
          outline-none
          transition
          focus:border-blue-400
          focus:ring-2
          focus:ring-blue-400/30"
      />
    </label>

    <label class="flex flex-col gap-2 text-sm">
      <span class="font-poppins tracking-wide"> Email </span>

      <input
        id="email"
        name="email"
        type="email"
        required
        autocomplete="email"
        class="rounded-lg
          border border-slate-600
          bg-slate-800
          px-4 py-3
          outline-none
          transition
          focus:border-blue-400
          focus:ring-2
          focus:ring-blue-400/30"
      />
    </label>

    <label class="flex flex-col gap-2 text-sm md:col-span-2">
      <span class="font-poppins tracking-wide"> Mensagem </span>

      <textarea
        id="message"
        name="message"
        rows="7"
        required
        class="resize-none
          rounded-lg
          border border-slate-600
          bg-slate-800
          px-4 py-3
          outline-none
          transition
          focus:border-blue-400
          focus:ring-2
          focus:ring-blue-400/30"
      ></textarea>
    </label>
  </div>

  <button type="submit" class="button primary-button mt-8">
    Enviar Mensagem 
    <Send size="18"/>
  </button>
</form>
