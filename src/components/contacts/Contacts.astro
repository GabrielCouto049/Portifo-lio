---
import { Mail, Phone, MapPin } from "@lucide/astro";
import ContactsForm from "./ContactsForm.astro";

const contactItems = [
  {
    label: "Email",
    value: "seuemail@email.com",
    href: "mailto:seuemail@email.com",
    icon: Mail,
  },
  {
    label: "Telefone",
    value: "+55 (00) 00000-0000",
    href: "tel:+550000000000",
    icon: Phone,
  },
  {
    label: "Localização",
    value: "Brasil",
    icon: MapPin,
  },
  {
    label: "GitHub",
    value: "github.com/seuusuario",
    href: "https://github.com/seuusuario",
  },
];
---

<!--REWORKING-->
<section
  id="contact"
  class="section
  grid gap-10
  bg-slate-800
  text-slate-50
  md:grid-cols-2"
>
  <div>
    <header>
      <h2
        class="mb-4
        font-poppins
        text-2xl font-semibold
        text-slate-50"
      >
        Vamos Conversar?
      </h2>

      <p
        class="mb-10
        max-w-120
        text-sm
        leading-relaxed
        tracking-wide
        text-slate-300"
      >
        Lorem ipsum dolor sit, amet consectetur adipisicing elit. Temporibus
        totam libero deserunt laboriosam magnam fugiat, deleniti illo assumenda
        mollitia fuga.
      </p>
    </header>

    <address class="space-y-6
      font-poppins
      text-sm
      not-italic">
      {
        contactItems.map(({ label, value, href, icon: Icon }) => (
          <div class="flex items-center gap-4">
            <div class="rounded-lg bg-slate-700 p-3">
              {Icon && (
                <Icon aria-hidden="true" size={18} class="text-blue-400" />
              )}
            </div>

            <div>
              <p class="text-slate-400">{label}</p>

              {href ? (
                <a
                  href={href}
                  target={href.startsWith("http") ? "_blank" : undefined}
                  rel={
                    href.startsWith("http") ? "noopener noreferrer" : undefined
                  }
                  class="transition hover:text-blue-400"
                >
                  {value}
                </a>
              ) : (
                <span>{value}</span>
              )}
            </div>
          </div>
        ))
      }
    </address>
  </div>
  <ContactsForm />
</section>
