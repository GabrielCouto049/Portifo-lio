---
import { SquareArrowOutUpRight } from "@lucide/astro";
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  title: string;
  description: string;
  imageSrc: ImageMetadata;
  technologies: string[];
  projectUrl: string;
  githubUrl: string;
}

const {
  title,
  description,
  imageSrc,
  technologies,
  projectUrl,
  githubUrl,
} = Astro.props;
---

<article
  class="flex flex-col rounded-xl border border-slate-200 bg-slate-50 p-5 shadow-sm transition-all duration-300 2xl:flex-row 2xl:items-stretch 2xl:gap-6"
>
  <!-- Imagem -->
  <Image
    src={imageSrc}
    alt={title}
    loading="lazy"
    class="aspect-video w-full rounded-lg border border-slate-200 object-cover 2xl:w-96 2xl:shrink-0"
  />

  <!-- Conteúdo -->
  <div class="mt-4 flex flex-1 flex-col justify-between 2xl:mt-0">
    <div>
      <h3 class="font-poppins text-lg font-semibold text-slate-900">
        {title}
      </h3>

      <p class="mt-2 text-sm leading-6 text-slate-600">
        {description}
      </p>

      <!-- Tecnologias -->
      <div class="mt-4 flex flex-wrap gap-2">
        {technologies.map((technology) => (
          <span class="technology-label">{technology}</span>
        ))}
      </div>
    </div>

    <!-- Footer -->
    <footer class="mt-6 flex items-center justify-between border-t border-slate-200 pt-4">
      <a
        href={projectUrl}
        class="flex items-center gap-1 text-sm font-medium text-slate-700 transition-colors hover:text-blue-500"
      >
        Ver projeto
        <SquareArrowOutUpRight size={15} />
      </a>

      <a
        href={githubUrl}
        class="flex items-center gap-1 text-sm font-medium text-slate-700 transition-colors hover:text-blue-500"
      >
        Código
        <SquareArrowOutUpRight size={15} />
      </a>
    </footer>
  </div>
</article>