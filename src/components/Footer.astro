---
import { CodeXml, ArrowUp } from "@lucide/astro";

const navigationLinks = [
  { label: "Sobre", href: "#about" },
  { label: "Experiência", href: "#experience" },
  { label: "Habilidades", href: "#skills" },
  { label: "Projetos", href: "#projects" },
  { label: "Contato", href: "#contact" },
];

const services = [
  "Desenvolvimento de Sites",
  "Manutenção e Suporte",
  "Otimização de Performance",
  "SEO Técnico",
  "Consultoria",
];
---

<footer
  class="bg-slate-900
  p-8
  text-slate-50
  transition-colors duration-300
  dark:bg-slate-950
  md:px-16 md:pt-16 md:pb-5"
>
  <div
    class="mb-8
    flex flex-col gap-8
    md:flex-row md:justify-between md:gap-0"
  >
    <section>
      <div
        class="mb-4
        flex items-center gap-2
        font-poppins
        text-2xl font-semibold"
      >
        <CodeXml
          aria-hidden="true"
          size={24}
          class="text-blue-500 transition-colors duration-300"
        />

        <span>
          GabrielCouto
        </span>
      </div>

      <p
        class="max-w-xs
        text-sm
        leading-relaxed
        tracking-wide
        text-slate-300
        transition-colors duration-300"
      >
        Desenvolvedor Web focado em criar experiências digitais rápidas,
        acessíveis e que geram resultados.
      </p>
    </section>

    <nav aria-label="Navegação do rodapé">
      <h3
        class="mb-4
        font-poppins
        text-lg font-semibold"
      >
        Navegação
      </h3>

      <ul
        class="space-y-3
        font-poppins
        text-sm
        text-slate-300"
      >
        {
          navigationLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class="transition-colors duration-300 hover:text-blue-400"
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <section>
      <h3
        class="mb-5
        font-poppins
        text-lg font-semibold"
      >
        Serviços
      </h3>

      <ul
        class="space-y-3
        font-poppins
        text-sm
        text-slate-300"
      >
        {
          services.map((service) => (
            <li>
              {service}
            </li>
          ))
        }
      </ul>
    </section>

    <section>
      <h3
        class="mb-5
        font-poppins
        text-lg font-semibold"
      >
        Redes Sociais
      </h3>

      <div class="flex gap-4">
        {
          Array.from({ length: 3 }).map(() => (
            <a
              href="#"
              aria-label="Rede social"
              class="flex h-14 w-14 items-center justify-center
              rounded-lg
              bg-slate-800
              transition-all duration-300
              hover:-translate-y-1
              hover:bg-blue-600"
            />
          ))
        }
      </div>
    </section>
  </div>

  <div
    class="mb-5
    h-px
    bg-slate-700
    transition-colors duration-300"
  ></div>

  <div
    class="flex flex-col gap-4
    text-xs
    text-slate-300
    md:flex-row md:items-center md:justify-between"
  >
    <p>
      © 2024 Gabriel Couto. Todos os direitos reservados.
    </p>

    <p>
      Feito com
      <span class="text-red-500">
        ❤
      </span>
      para a web
    </p>

    <a
      href="#hero"
      class="flex items-center gap-2
      transition-colors duration-300
      hover:text-blue-400"
    >
      Voltar ao topo

      <ArrowUp
        aria-hidden="true"
        size={18}
        class="transition-transform duration-300 hover:-translate-y-1"
      />
    </a>
  </div>
</footer>