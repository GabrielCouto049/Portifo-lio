---
import { Hand } from "@lucide/astro";
---

<section
  class="flex-center flex-col md:flex-row gap-16 px-8 py-12 md:px-24 md:py-20
  bg-[url(../assets/hero-background.png)] dark:bg-[url(../assets/hero-dark.png)] bg-left md:bg-right bg-cover
  bg-white text-slate-900
  dark:bg-slate-900 dark:text-slate-100
  transition-colors duration-300"
>
  <div class="flex-1">
    <p
      class="flex-center gap-2 w-fit rounded-full border
      border-slate-300 dark:border-slate-700
      bg-white/70 dark:bg-slate-800/70
      px-2 py-0.5 text-xs
      text-slate-600 dark:text-slate-300
      transition-colors duration-300"
    >
      <Hand
        size="14"
        class="text-slate-600 dark:text-slate-300 transition-colors duration-300"
      />
      Olá, eu sou
    </p>

    <div class="mt-5 mb-6">
      <h1
        class="mb-1 font-poppins text-5xl font-bold
        text-slate-900 dark:text-slate-100
        transition-colors duration-300"
      >
        Gabriel

        <span
          class="ml-3 bg-linear-to-b from-blue-500 to-blue-600 bg-clip-text text-transparent"
        >
          Couto
        </span>
      </h1>

      <div class="flex-center gap-2">
        <h2
          id="typed"
          class="w-fit h-8 bg-linear-to-b from-blue-500 to-blue-600 bg-clip-text
          font-poppins text-2xl font-semibold text-transparent"
        >
          <!-- Typing animation -->
        </h2>
      </div>
    </div>

    <p
      class="mb-8 max-w-100 text-sm leading-6 tracking-wide
      text-slate-700 dark:text-slate-300
      transition-colors duration-300"
    >
      Lorem ipsum dolor sit amet consectetur adipisicing elit. Eaque esse
      accusantium eum praesentium exercitationem omnis deserunt porro, dolorum,
      laudantium saepe fugit, facere quis quibusdam eos.
    </p>

    <div class="flex-center flex-col md:flex-row max-w-100 gap-6">
      <button class="primary-button w-full">
        Baixar currículo
      </button>

      <button class="secondary-button w-full">
        Entrar em contato
      </button>
    </div>
  </div>

  <div class="flex-1">
    <img src="" alt="" class="transition-all duration-300" />
  </div>
</section>

<script src="../animations/typing"></script>
