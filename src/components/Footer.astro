---
import { CodeXml, ArrowUp } from "@lucide/astro";
---

<footer
  class="bg-slate-900 dark:bg-slate-950 text-slate-50 transition-colors duration-300 p-8 md:px-16 md:pt-16 md:pb-5"
>
  <!-- Parte superior -->
  <div class="mb-8 flex flex-col gap-8 md:flex-row md:justify-between md:gap-0">
    <!-- Logo -->
    <div>
      <div
        class="mb-4 flex items-center gap-2 font-poppins text-2xl font-semibold"
      >
        <CodeXml
          size={24}
          class="text-blue-500 transition-colors duration-300"
        />
        <span>GabrielCouto</span>
      </div>

      <p
        class="max-w-xs text-sm leading-relaxed tracking-wide text-slate-300 transition-colors duration-300"
      >
        Desenvolvedor Web focado em criar experiências digitais rápidas,
        acessíveis e que geram resultados.
      </p>
    </div>

    <!-- Navegação -->
    <div>
      <h3 class="mb-4 font-poppins text-lg font-semibold">
        Navegação
      </h3>

      <ul class="space-y-3 font-poppins text-sm text-slate-300">
        <li>
          <a class="transition-colors duration-300 hover:text-blue-400" href="#about">
            Sobre
          </a>
        </li>
        <li>
          <a class="transition-colors duration-300 hover:text-blue-400" href="#experience">
            Experiência
          </a>
        </li>
        <li>
          <a class="transition-colors duration-300 hover:text-blue-400" href="#skills">
            Habilidades
          </a>
        </li>
        <li>
          <a class="transition-colors duration-300 hover:text-blue-400" href="#projects">
            Projetos
          </a>
        </li>
        <li>
          <a class="transition-colors duration-300 hover:text-blue-400" href="#contact">
            Contato
          </a>
        </li>
      </ul>
    </div>

    <!-- Serviços -->
    <div>
      <h3 class="mb-5 font-poppins text-lg font-semibold">
        Serviços
      </h3>

      <ul class="space-y-3 font-poppins text-sm text-slate-300">
        <li>Desenvolvimento de Sites</li>
        <li>Manutenção e Suporte</li>
        <li>Otimização de Performance</li>
        <li>SEO Técnico</li>
        <li>Consultoria</li>
      </ul>
    </div>

    <!-- Redes -->
    <div>
      <h3 class="mb-5 font-poppins text-lg font-semibold">
        Redes Sociais
      </h3>

      <div class="flex gap-4">
        <a
          href="#"
          class="flex h-14 w-14 items-center justify-center rounded-lg
          bg-slate-800
          transition-all duration-300
          hover:-translate-y-1
          hover:bg-blue-600"
        >
          <!-- Ícone -->
        </a>

        <a
          href="#"
          class="flex h-14 w-14 items-center justify-center rounded-lg
          bg-slate-800
          transition-all duration-300
          hover:-translate-y-1
          hover:bg-blue-600"
        >
          <!-- Ícone -->
        </a>

        <a
          href="#"
          class="flex h-14 w-14 items-center justify-center rounded-lg
          bg-slate-800
          transition-all duration-300
          hover:-translate-y-1
          hover:bg-blue-600"
        >
          <!-- Ícone -->
        </a>
      </div>
    </div>
  </div>

  <!-- Linha -->
  <div class="mb-5 h-px bg-slate-700 transition-colors duration-300"></div>

  <!-- Parte inferior -->
  <div
    class="flex flex-col gap-4 text-xs text-slate-300 md:flex-row md:items-center md:justify-between"
  >
    <p>© 2024 Gabriel Couto. Todos os direitos reservados.</p>

    <p>
      Feito com
      <span class="text-red-500">❤</span>
      para a web
    </p>

    <a
      href="#"
      class="flex items-center gap-2 transition-colors duration-300 hover:text-blue-400"
    >
      Voltar ao topo
      <ArrowUp
        size={18}
        class="transition-transform duration-300 hover:-translate-y-1"
      />
    </a>
  </div>
</footer>