---
export interface Props {
  title: string;
  subtitle: string;
  start: number;
  end: number | "Atual";
}

const { title, subtitle, start, end } = Astro.props;
---

<li class="relative grid grid-cols-[1fr_auto] items-start gap-4">
  <span
    class="absolute -left-8.75 top-1.5 h-3 w-3 rounded-full border-[3px]
    border-blue-500 bg-white dark:bg-slate-800
    transition-colors duration-300"
  ></span>

  <div>
    <h4
      class="font-poppins font-semibold
      text-slate-900 dark:text-slate-100
      transition-colors duration-300"
    >
      {title}
    </h4>

    <p
      class="mt-1 text-sm
      text-slate-600 dark:text-slate-400
      transition-colors duration-300"
    >
      {subtitle}
    </p>
  </div>

  <span
    class="whitespace-nowrap text-sm font-semibold
    text-slate-500 dark:text-slate-400
    transition-colors duration-300"
  >
    {start} – {end}
  </span>
</li>