---
import { SquareArrowOutUpRight } from "@lucide/astro";
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  title: string;
  description: string;
  imageSrc: ImageMetadata;
  technologies: string[];
  projectUrl: string;
  githubUrl: string;
}

const {
  title,
  description,
  imageSrc,
  technologies,
  projectUrl,
  githubUrl,
} = Astro.props;
---

<article
  class="flex flex-col rounded-xl
  border border-slate-200 dark:border-slate-700
  bg-slate-50 dark:bg-slate-800
  p-5 shadow-sm
  transition-all duration-300
  hover:-translate-y-1 hover:shadow-lg
  2xl:flex-row 2xl:items-stretch 2xl:gap-6"
>
  <!-- Imagem -->
  <Image
    src={imageSrc}
    alt={title}
    loading="lazy"
    class="aspect-video w-full rounded-lg
    border border-slate-200 dark:border-slate-700
    object-cover
    transition-all duration-300
    2xl:w-96 2xl:shrink-0"
  />

  <!-- Conteúdo -->
  <div class="mt-4 flex flex-1 flex-col justify-between 2xl:mt-0">
    <div>
      <h3
        class="font-poppins text-lg font-semibold
        text-slate-900 dark:text-slate-100
        transition-colors duration-300"
      >
        {title}
      </h3>

      <p
        class="mt-2 text-sm leading-6
        text-slate-600 dark:text-slate-300
        transition-colors duration-300"
      >
        {description}
      </p>

      <!-- Tecnologias -->
      <div class="mt-4 flex flex-wrap gap-2">
        {technologies.map((technology) => (
          <span class="technology-label">{technology}</span>
        ))}
      </div>
    </div>

    <!-- Footer -->
    <footer
      class="mt-6 flex items-center justify-between
      border-t border-slate-200 dark:border-slate-700
      pt-4 transition-colors duration-300"
    >
      <a
        href={projectUrl}
        class="flex items-center gap-1
        text-sm font-medium
        text-slate-700 dark:text-slate-300
        transition-colors duration-300
        hover:text-blue-500 dark:hover:text-blue-400"
      >
        Ver projeto
        <SquareArrowOutUpRight size={15} />
      </a>

      <a
        href={githubUrl}
        class="flex items-center gap-1
        text-sm font-medium
        text-slate-700 dark:text-slate-300
        transition-colors duration-300
        hover:text-blue-500 dark:hover:text-blue-400"
      >
        Código
        <SquareArrowOutUpRight size={15} />
      </a>
    </footer>
  </div>
</article>