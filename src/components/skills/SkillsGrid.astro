---
import { Image } from "astro:assets";

interface Props {
  title: string;
  icon: any;
  skills: {
    title: string;
    iconSrc: any;
  }[];
  columns?: string;
}

const {
  title,
  icon: Icon,
  skills,
  columns = "grid-cols-2 sm:grid-cols-3",
} = Astro.props;
---

<article>
  <div class="flex-center mb-8 gap-2">
    <Icon />
    <h3 class="font-poppins text-xl font-semibold text-blue-500">
      {title}
    </h3>
  </div>

  <div class={`grid gap-5 ${columns}`}>
    {
      skills.map((skill) => (
        <div class="skill-card">
          <Image
            src={skill.iconSrc}
            alt={skill.title}
            loading="lazy"
            class="mb-4 size-11 transition-transform duration-300 group-hover:scale-110"
          />

          <span class="text-center text-sm font-medium text-slate-600 dark:text-slate-300 transition-colors duration-300">
            {skill.title}
          </span>
        </div>
      ))
    }
  </div>
</article>