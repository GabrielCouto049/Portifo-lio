---
import { GraduationCap, BriefcaseBusiness } from "@lucide/astro";
import ExperienceItem from "./ExperienceItem.astro";

import {
  graduations,
  jobExperiences,
} from "../../data/experience";

const experienceSections = [
  {
    title: "Educação",
    icon: GraduationCap,
    items: graduations,
  },
  {
    title: "Experiências Profissionais",
    icon: BriefcaseBusiness,
    items: jobExperiences,
  },
];
---

<!--REWORKING-->

<section
  id="about"
  class="section min-h-screen w-full
  bg-white transition-colors duration-300
  dark:bg-slate-900"
>
  <!-- ABOUT -->
  <div
    class="mb-16 grid items-center gap-10
    lg:grid-cols-[1fr_350px]"
  >
    <div>
      <h2 class="section-title mb-6">
        Sobre mim
      </h2>

      <p
        class="max-w-3xl font-poppins text-base
        leading-relaxed text-slate-600
        dark:text-slate-300 sm:text-lg"
      >
        Olá! Sou um desenvolvedor apaixonado por tecnologia,
        criação de interfaces e resolução de problemas.
        Tenho experiência desenvolvendo aplicações modernas,
        buscando sempre escrever código limpo, acessível
        e eficiente.

        <br /><br />

        Minha jornada envolve aprendizado constante,
        colaboração em equipe e a busca por transformar
        ideias em experiências digitais bem construídas.
      </p>
    </div>

    <!-- FOTO -->
    <div class="flex justify-center lg:justify-end">
      <div
        class="h-64 w-64 overflow-hidden rounded-3xl
        border border-slate-200 shadow-lg
        dark:border-slate-700"
      >
        <img
          src="/images/profile.jpg"
          alt="Foto de perfil"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
  </div>


  <!-- EXPERIÊNCIA -->
  <div>
    <div class="grid w-full gap-8 lg:grid-cols-2">
      {
        experienceSections.map(({ title, icon: Icon, items }) => (
          <article
            class="w-full rounded-2xl border border-slate-200
            bg-white p-5 shadow-sm
            transition-all duration-300
            sm:p-8
            dark:border-slate-700
            dark:bg-slate-800"
          >
            <header
              class="mb-8 flex items-center gap-3
              font-poppins text-lg font-semibold
              text-blue-500 sm:text-xl"
            >
              <Icon
                aria-hidden="true"
                size="27"
              />

              <h3>
                {title}
              </h3>
            </header>

            <ul
              class="relative flex flex-col gap-8
              pl-8 sm:pl-10"
            >
              <span
                aria-hidden="true"
                class="absolute left-2 top-2 bottom-2 w-0.5
                bg-slate-200
                dark:bg-slate-600"
              ></span>

              {
                items.map((item) => (
                  <ExperienceItem {...item} />
                ))
              }
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>