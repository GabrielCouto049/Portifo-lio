---
import { CodeXml, ArrowUp } from "@lucide/astro";
---

<footer class="p-8 md:px-16 md:pt-16 md:pb-8 bg-slate-800 text-slate-50 ">
  <!-- Parte superior -->
  <div class="flex flex-col gap-8 mb-8 md:flex-row md:items-center md:justify-between md:gap-0">
    <!-- Logo -->
    <div>
      <div class="mb-4 flex items-center gap-2 text-2xl font-poppins font-semibold">
        <CodeXml size={24} class="text-blue-700" />
        <span>GabrielCouto</span>
      </div>

      <p class="max-w-xs text-sm leading-relaxed tracking-wide text-slate-300">
        Desenvolvedor Web focado em criar experiências digitais rápidas,
        acessíveis e que geram resultados.
      </p>
    </div>

    <!-- Navegação -->
    <div>
      <h3 class="mb-4 font-poppins text-lg font-semibold">Navegação</h3>

      <ul class="space-y-3 text-sm text-slate-300 font-poppins">
        <li><a href="#about">Sobre</a></li>
        <li><a href="#experience">Experiência</a></li>
        <li><a href="#skills">Habilidades</a></li>
        <li><a href="#projects">Projetos</a></li>
        <li><a href="#contact">Contato</a></li>
      </ul>
    </div>

    <!-- Serviços -->
    <div>
      <h3 class="mb-5 font-poppins text-lg font-semibold">Serviços</h3>

      <ul class="space-y-3 text-sm text-slate-300 font-poppins">
        <li>Desenvolvimento de Sites</li>
        <li>Manutenção e Suporte</li>
        <li>Otimização de Performance</li>
        <li>SEO Técnico</li>
        <li>Consultoria</li>
      </ul>
    </div>

    <!-- Redes -->
    <div>
      <h3 class="mb-5 font-poppins text-lg font-semibold">Redes Sociais</h3>

      <div class="flex gap-4">
        <a
          href="#"
          class="flex h-14 w-14 items-center justify-center rounded-lg bg-slate-900 transition hover:bg-slate-700"
        >

        </a>

        <a
          href="#"
          class="flex h-14 w-14 items-center justify-center rounded-lg bg-slate-900 transition hover:bg-slate-700"
        >

        </a>

        <a
          href="#"
          class="flex h-14 w-14 items-center justify-center rounded-lg bg-slate-900 transition hover:bg-slate-700"
        >
        </a>
      </div>
    </div>
  </div>

  <!-- Linha -->
  <div class="mb-8 h-px bg-slate-500"></div>

  <!-- Parte inferior -->
  <div class="flex flex-col text-xs gap-4 text-slate-300 md:flex-row md:items-center md:justify-between">
    <p>© 2024 Gabriel Couto. Todos os direitos reservados.</p>

    <p>
      Feito com
      <span class="text-red-500">❤</span>
      para a web
    </p>

    <a href="#" class="flex items-center gap-2">
      Voltar ao topo
      <ArrowUp size={18} />
    </a>
  </div>
</footer>