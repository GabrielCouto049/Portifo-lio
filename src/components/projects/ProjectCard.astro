---
import { SquareArrowOutUpRight } from "@lucide/astro";
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  title: string;
  description: string;
  imageSrc: ImageMetadata;
  technologies: string[];
  projectUrl: string;
  githubUrl: string;
}

const {
  title,
  description,
  imageSrc,
  technologies,
  projectUrl,
  githubUrl,
} = Astro.props;
---

<article
  class="group observed
  flex flex-col
  rounded-xl
  border border-slate-200
  bg-slate-50
  p-5 shadow-sm
  transition-all duration-300
  hover:-translate-y-1 hover:shadow-lg
  dark:border-slate-700
  dark:bg-slate-800
  2xl:flex-row 2xl:items-stretch 2xl:gap-6"
>
  <Image
    src={imageSrc}
    alt={`Imagem do projeto ${title}`}
    loading="lazy"
    class="aspect-video w-full
    rounded-lg
    border border-slate-200
    object-cover
    transition-all duration-300
    dark:border-slate-700
    2xl:w-96 2xl:shrink-0"
  />

  <div
    class="mt-4 flex flex-1 flex-col justify-between
    2xl:mt-0"
  >
    <div>
      <h3
        class="font-poppins text-lg font-semibold
        text-slate-900
        transition-colors duration-300
        dark:text-slate-100"
      >
        {title}
      </h3>

      <p
        class="mt-2 text-sm leading-6
        text-slate-600
        transition-colors duration-300
        dark:text-slate-300"
      >
        {description}
      </p>

      <div class="mt-4 flex flex-wrap gap-2">
        {
          technologies.map((technology) => (
            <span class="technology-label">
              {technology}
            </span>
          ))
        }
      </div>
    </div>

    <footer
      class="mt-6 flex items-center justify-between
      border-t border-slate-200
      pt-4
      transition-colors duration-300
      dark:border-slate-700"
    >
      <a
        href={projectUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1
        text-sm font-medium
        text-slate-700
        transition-colors duration-300
        hover:text-blue-500
        dark:text-slate-300
        dark:hover:text-blue-400"
      >
        Ver projeto

        <SquareArrowOutUpRight
          aria-hidden="true"
          size={15}
        />
      </a>

      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1
        text-sm font-medium
        text-slate-700
        transition-colors duration-300
        hover:text-blue-500
        dark:text-slate-300
        dark:hover:text-blue-400"
      >
        Código

        <SquareArrowOutUpRight
          aria-hidden="true"
          size={15}
        />
      </a>
    </footer>
  </div>
</article>