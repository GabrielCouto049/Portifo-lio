---
import { GraduationCap, BriefcaseBusiness } from "@lucide/astro";
import ExperienceItem from "./ExperienceItem.astro";
import { graduations, jobExperiences } from "../../data/experience";
---

<section
  id="experience"
  class="section transition-colors duration-300
  bg-white dark:bg-slate-900"
>
  <h2 class="section-title transition-colors duration-300">
    Experiência
  </h2>

  <div class="grid gap-10 lg:grid-cols-2">
    <!-- Educação -->
    <article
      class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm
      dark:border-slate-700 dark:bg-slate-800
      transition-all duration-300"
    >
      <h3
        class="mb-8 flex items-center gap-3 font-poppins text-xl font-semibold
        text-blue-500 transition-colors duration-300"
      >
        <GraduationCap size="27" />
        Educação
      </h3>

      <ul class="relative flex flex-col gap-8 pl-10">
        <!-- Linha da timeline -->
        <span
          class="absolute left-2.5 top-2 h-[calc(100%-16px)] w-0.5
          bg-slate-200 dark:bg-slate-600
          transition-colors duration-300"
        ></span>

        {graduations.map((graduation) => (
          <ExperienceItem {...graduation} />
        ))}
      </ul>
    </article>

    <!-- Experiência -->
    <article
      class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm
      dark:border-slate-700 dark:bg-slate-800
      transition-all duration-300"
    >
      <h3
        class="mb-8 flex items-center gap-3 font-poppins text-xl font-semibold
        text-blue-500 transition-colors duration-300"
      >
        <BriefcaseBusiness size="24" />
        Experiências Profissionais
      </h3>

      <ul class="relative flex flex-col gap-8 pl-10">
        <!-- Linha da timeline -->
        <span
          class="absolute left-2.5 top-2 h-[calc(100%-16px)] w-0.5
          bg-slate-200 dark:bg-slate-600
          transition-colors duration-300"
        ></span>

        {jobExperiences.map((experience) => (
          <ExperienceItem {...experience} />
        ))}
      </ul>
    </article>
  </div>
</section>