---
export interface Props {
  title: string;
  subtitle: string;
  start: number;
  end: number | "Atual";
}

const {
  title,
  subtitle,
  start,
  end,
} = Astro.props;
---

<li
  class="relative grid grid-cols-1 gap-2 sm:grid-cols-[1fr_auto] sm:items-start"
>
  <span
    aria-hidden="true"
    class="absolute -left-7.25 top-2
    h-3 w-3
    rounded-full
    border-[3px]
    border-blue-500
    bg-white
    dark:bg-slate-800
    md:-left-9.25"
  ></span>

  <div class="min-w-0">
    <h4
      class="wrap-break-words
      font-poppins font-semibold
      text-slate-900
      dark:text-slate-100"
    >
      {title}
    </h4>

    <p
      class="mt-1
      wrap-break-words
      text-sm
      text-slate-600
      dark:text-slate-400"
    >
      {subtitle}
    </p>
  </div>

  <time
    class="text-sm font-semibold
    text-slate-500
    dark:text-slate-400
    sm:text-right"
  >
    {start} – {end}
  </time>
</li>