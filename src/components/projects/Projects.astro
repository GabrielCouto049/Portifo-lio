---
import { projects } from "../../data/projects";
import ProjectCard from "./ProjectCard.astro";

const projectsPerPage = 4;
const totalPages = Math.ceil(projects.length / projectsPerPage);
---

<section
  id="projects"
  class="section bg-white transition-colors duration-300 dark:bg-slate-900"
>
  <h2 class="section-title observed">Meus Projetos</h2>

  <div
    id="projects-grid"
    class="grid gap-10 md:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-2"
  >
    {
      projects.map((project, index) => (
        <div
          class="project-item"
          data-page={Math.floor(index / projectsPerPage) + 1}
        >
          <ProjectCard {...project} />
        </div>
      ))
    }
  </div>

  <nav
    class="mt-14 flex items-center justify-center gap-3"
    aria-label="Paginação de projetos"
  >
    {
      Array.from({ length: totalPages }, (_, index) => (
        <button
          class:list={[
            "page-button",
            "flex h-11 w-11 items-center justify-center rounded-lg border text-sm font-semibold transition-all duration-300",
            index === 0
              ? "border-blue-600 bg-blue-600 text-white"
              : "border-slate-300 bg-white text-slate-700 hover:-translate-y-1 hover:border-blue-500 hover:text-blue-600 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:border-blue-500 dark:hover:text-blue-400",
          ]}
          data-page={index + 1}
        >
          {index + 1}
        </button>
      ))
    }
  </nav>
</section>

<script src="../../utils/pagination.js"></script>