---
import { Hand } from "@lucide/astro";
---

<section
  id="hero"
  class="section min-h-[calc(100vh-72px)] flex-center flex-col gap-16
  bg-white text-slate-900
  bg-[url(../assets/hero-background.png)]
  bg-left bg-cover
  transition-colors duration-300
  dark:bg-slate-900 dark:text-slate-100
  dark:bg-[url(../assets/hero-dark.png)]
  md:flex-row md:px-24 md:py-20 md:bg-right"
>
  <div class="flex-1">
    <p
      class="flex-center w-fit gap-2 rounded-full border
      border-slate-300
      bg-white/70
      px-3 py-1
      text-sm
      text-slate-600
      transition-colors duration-300
      dark:border-slate-700
      dark:bg-slate-800/70
      dark:text-slate-300"
    >
      <Hand
        aria-hidden="true"
        size="16"
        class="text-slate-600 dark:text-slate-300"
      />

      Olá, eu sou
    </p>

    <div class="mb-8 mt-6">
      <h1
        class="mb-2
        font-poppins
        text-5xl font-bold
        text-slate-900
        transition-colors duration-300
        dark:text-slate-100
        lg:text-7xl
        xl:text-8xl"
      >
        Gabriel

        <span
          class="ml-3 bg-linear-to-b from-blue-500 to-blue-600
          bg-clip-text text-transparent"
        >
          Couto
        </span>
      </h1>

      <div class="flex-center gap-2">
        <h2
          id="typed"
          aria-label="Especialidade profissional"
          class="h-10 w-fit
          bg-linear-to-b from-blue-500 to-blue-600
          bg-clip-text
          font-poppins text-2xl font-semibold
          text-transparent
          lg:text-4xl"
        >
        </h2>
      </div>
    </div>

    <p
      class="mb-10 max-w-xl
      text-base
      leading-7
      tracking-wide
      text-slate-700
      transition-colors duration-300
      dark:text-slate-300
      lg:text-lg"
    >
      Lorem ipsum dolor sit amet consectetur adipisicing elit. Eaque esse
      accusantium eum praesentium exercitationem omnis deserunt porro, dolorum,
      laudantium saepe fugit, facere quis quibusdam eos.
    </p>

    <div
      class="flex-center max-w-xl flex-col gap-6 md:flex-row"
    >
      <button
        type="button"
        class="button primary-button w-full"
      >
        Baixar currículo
      </button>

      <button
        type="button"
        class="button secondary-button w-full"
      >
        Entrar em contato
      </button>
    </div>
  </div>

  <div class="flex-1 flex-center">
    <img
      src=""
      alt="Imagem de apresentação de Gabriel Couto"
      loading="lazy"
      class="max-w-lg transition-all duration-300"
    />
  </div>
</section>

<script src="../animations/typing.js"></script>