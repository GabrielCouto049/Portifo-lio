---
import { Mail, Phone, MapPin } from "@lucide/astro";

const contactItems = [
  {
    label: "Email",
    value: "seuemail@email.com",
    href: "mailto:seuemail@email.com",
    icon: Mail,
  },
  {
    label: "Telefone",
    value: "+55 (00) 00000-0000",
    href: "tel:+550000000000",
    icon: Phone,
  },
  {
    label: "Localização",
    value: "Brasil",
    icon: MapPin,
  },
  {
    label: "GitHub",
    value: "github.com/seuusuario",
    href: "https://github.com/seuusuario",
  },
];
---

<section
  id="contact"
  class="section
  grid gap-10
  bg-slate-800
  text-slate-50
  md:grid-cols-2"
>
  <div>
    <header>
      <h2
        class="mb-4
        font-poppins
        text-2xl font-semibold
        text-slate-50"
      >
        Vamos Conversar?
      </h2>

      <p
        class="mb-10
        max-w-120
        text-sm
        leading-relaxed
        tracking-wide
        text-slate-300"
      >
        Lorem ipsum dolor sit, amet consectetur adipisicing elit. Temporibus totam
        libero deserunt laboriosam magnam fugiat, deleniti illo assumenda mollitia
        fuga.
      </p>
    </header>

    <address
      class="space-y-6
      font-poppins
      text-sm
      not-italic"
    >
      {
        contactItems.map(({ label, value, href, icon: Icon }) => (
          <div class="flex items-center gap-4">
            <div class="rounded-lg bg-slate-700 p-3">
              {
                Icon && (
                  <Icon
                    aria-hidden="true"
                    size={18}
                    class="text-blue-400"
                  />
                )
              }
            </div>

            <div>
              <p class="text-slate-400">
                {label}
              </p>

              {
                href ? (
                  <a
                    href={href}
                    target={href.startsWith("http") ? "_blank" : undefined}
                    rel={
                      href.startsWith("http")
                        ? "noopener noreferrer"
                        : undefined
                    }
                    class="transition hover:text-blue-400"
                  >
                    {value}
                  </a>
                ) : (
                  <span>
                    {value}
                  </span>
                )
              }
            </div>
          </div>
        ))
      }
    </address>
  </div>

  <form
    class="rounded-2xl
    bg-slate-900/40
    p-8
    backdrop-blur"
  >
    <div class="grid gap-6 md:grid-cols-2">
      <label class="flex flex-col gap-2 text-sm">
        <span class="font-poppins tracking-wide">
          Nome
        </span>

        <input
          id="name"
          name="name"
          type="text"
          required
          autocomplete="name"
          class="rounded-lg
          border border-slate-600
          bg-slate-800
          px-4 py-3
          outline-none
          transition
          focus:border-blue-400
          focus:ring-2
          focus:ring-blue-400/30"
        />
      </label>

      <label class="flex flex-col gap-2 text-sm">
        <span class="font-poppins tracking-wide">
          Email
        </span>

        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          class="rounded-lg
          border border-slate-600
          bg-slate-800
          px-4 py-3
          outline-none
          transition
          focus:border-blue-400
          focus:ring-2
          focus:ring-blue-400/30"
        />
      </label>

      <label class="flex flex-col gap-2 text-sm md:col-span-2">
        <span class="font-poppins tracking-wide">
          Mensagem
        </span>

        <textarea
          id="message"
          name="message"
          rows="7"
          required
          class="resize-none
          rounded-lg
          border border-slate-600
          bg-slate-800
          px-4 py-3
          outline-none
          transition
          focus:border-blue-400
          focus:ring-2
          focus:ring-blue-400/30"
        ></textarea>
      </label>
    </div>

    <button
      type="submit"
      class="primary-button mt-8"
    >
      Enviar Mensagem
    </button>
  </form>
</section>