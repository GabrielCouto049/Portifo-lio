---
import { CodeXml, Download, Menu, Moon, Sun } from "@lucide/astro";

const navItems = [
  { label: "Home", href: "#hero" },
  { label: "Sobre", href: "#about" },
  { label: "Habilidades", href: "#skills" },
  { label: "Projetos", href: "#projects" },
  { label: "Contato", href: "#contact" },
];
---

<header
  id="header"
  class="fixed top-0 left-0 z-50 w-full
  flex-center justify-between
  p-6 md:px-16 md:py-6
  backdrop-blur-3xl
  bg-slate-100 dark:bg-slate-900
  lg:bg-transparent lg:dark:bg-slate-900/80
  text-slate-900 dark:text-slate-100
  transition-all duration-300"
>
  <a
    href="#hero"
    aria-label="Voltar para o início"
    class="flex items-center gap-2 font-poppins"
  >
    <CodeXml
      aria-hidden="true"
      color="#3b82f6"
      size="24"
      stroke-width="2.25"
    />

    <span class="text-2xl font-semibold">
      GabrielCouto
    </span>
  </a>

  <nav aria-label="Navegação principal" class="hidden lg:block">
    <ul class="flex items-center gap-12">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="nav-link transition-colors duration-300 hover:text-blue-500"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="flex-center gap-6">
    <a
      href="/curriculo.pdf"
      download
      class="primary-button hidden items-center gap-2 sm:flex"
    >
      <span>
        Baixar currículo
      </span>

      <Download
        aria-hidden="true"
        size="16"
        stroke-width="2.5"
      />
    </a>

    <button
      type="button"
      aria-label="Alternar tema"
      class="theme-button icon-button hidden items-center justify-center lg:flex"
    >
      <Moon
        id="moon-icon"
        aria-hidden="true"
        size="16"
        class="text-slate-500 dark:hidden"
      />

      <Sun
        id="sun-icon"
        aria-hidden="true"
        size="16"
        class="hidden text-slate-300 dark:block"
      />
    </button>

    <button
      type="button"
      id="menu-button"
      aria-label="Abrir menu"
      class="icon-button flex items-center justify-center bg-slate-100 dark:bg-slate-800 lg:hidden"
    >
      <Menu aria-hidden="true" />
    </button>
  </div>
</header>