---
import SkillsGrid from "./SkillsGrid.astro";

import {
  frontEndSkills,
  backEndSkills,
  toolsSkills,
  softSkills,
} from "../../data/skills";

import { Server, MonitorSmartphone, Wrench, Users } from "@lucide/astro";
import Image from "astro/components/Image.astro";
---

<section
  id="skills"
  class="section bg-slate-100 transition-colors duration-700 dark:bg-slate-800"
>
  <h2 class="section-title observed">Habilidades</h2>

  <div class="grid gap-10 lg:grid-cols-2">
    <SkillsGrid
      title="Front-end"
      icon={MonitorSmartphone}
      skills={frontEndSkills}
    />

    <div class="lg:col-span-2">
      <SkillsGrid
        title="Ferramentas"
        icon={Wrench}
        skills={toolsSkills}
        columns="grid-cols-3 md:grid-cols-4 lg:grid-cols-6"
      />
    </div>

    <article class="min-w-0 lg:col-span-2">
      <header class="flex-center mb-8 gap-2">
        <Users aria-hidden="true" />
        <h3 class="font-poppins text-xl font-semibold text-blue-500">
          Soft Skills
        </h3>
      </header>

      <div
        id="cardsScroll"
        class="flex snap-x snap-mandatory gap-5 scrollbar-none overflow-x-auto scroll-smooth pb-2 md:grid md:grid-cols-2 md:overflow-visible lg:grid-cols-4"
      >
        {
          softSkills.map((skill, index) => (
            <div
              id={`${index}`}
              class="group softSkillCard w-full shrink-0 snap-center rounded-2xl border border-slate-200 bg-linear-to-br from-white to-slate-50 p-6 transition-all duration-300 hover:-translate-y-2 hover:border-blue-500 hover:shadow-xl dark:border-slate-700 dark:from-slate-900 dark:to-slate-800"
            >
              <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-blue-50 dark:bg-blue-950/40">
                <Image
                  src={skill.iconSrc}
                  alt={skill.title}
                  loading="lazy"
                  class="size-8 transition-transform duration-300 group-hover:scale-110"
                />
              </div>

              <h4 class="mb-3 font-poppins text-lg font-semibold text-slate-800 dark:text-slate-100">
                {skill.title}
              </h4>

              <p class="text-sm leading-6 text-slate-600 dark:text-slate-300">
                {skill.description}
              </p>
            </div>
          ))
        }
      </div>

      <div class="mt-6 flex justify-center gap-2 md:hidden">
        {
          softSkills.map((skill, index) => (
            <div
              id={`marker-${index}`}
              class="h-2 w-2 rounded-full transition-all duration-300 bg-white"
            />
          ))
        }
      </div>
    </article>
  </div>
</section>

<script src="../../animations/carousselMarker.js"></script>